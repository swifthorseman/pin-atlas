{
  "config": {
    "default": true,
    "MD013": {
      "line_length": 80,
      "code_blocks": false,
      "tables": false,
      "headings": false,
      "stern": true
    },
    "MD024": {
      "siblings_only": true
    }
  },
  "globs": ["**/*.md"],
  "ignores": ["node_modules", "dist", "**/node_modules", ".claude"]
}
